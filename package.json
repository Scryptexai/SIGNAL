{
  "name": "signal-agent",
  "version": "1.0.0",
  "description": "Autonomous X content agent — Eskatologi Digital",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/data dist/data",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dry-run": "POST_MODE=dry-run tsx src/index.ts",
    "generate": "tsx src/agent/ContentBrain.ts",
    "test": "npm run build && node --test src/test/e2e.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "twitter-api-v2": "^1.17.0",
    "uuid": "^9.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.7.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
